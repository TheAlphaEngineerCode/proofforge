{
  "name": "@proofforge/agents",
  "version": "0.1.0",
  "description": "Specialised agents that read a change and report on it.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke-review.ts",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage .turbo"
  },
  "dependencies": {
    "@proofforge/ai-providers": "workspace:*",
    "@proofforge/observability": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
