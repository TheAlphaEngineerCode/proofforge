# ─────────────────────────────────────────────────────────────
# ProofForge — example environment. Copy to .env and adjust.
# NEVER commit a real .env. No production secrets in this file.
# ─────────────────────────────────────────────────────────────

# Node
NODE_ENV=development
LOG_LEVEL=info

# API
API_HOST=0.0.0.0
API_PORT=3001
API_BASE_URL=http://localhost:3001

# Web
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000

# PostgreSQL (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=proofforge
POSTGRES_PASSWORD=proofforge
POSTGRES_DB=proofforge
DATABASE_URL=postgresql://proofforge:proofforge@localhost:5432/proofforge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in dev, S3-compatible in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=proofforge-evidence
S3_ACCESS_KEY=proofforge
S3_SECRET_KEY=proofforge-secret

# GitHub App (fill in when configuring Phase 5)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# AI providers (Phase 7 — provider-agnostic layer)
AI_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Evidence signing (ed25519). Leave empty to produce unsigned manifests.
PROOFFORGE_SIGNING_PRIVATE_KEY=
PROOFFORGE_SIGNING_PUBLIC_KEY_ID=
